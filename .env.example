# Database
# Local: SQLite (npx prisma migrate dev)
# Production: Neon PostgreSQL (auto from Vercel env)
DATABASE_URL="postgresql://user:***@host:5432/db"
# Production: Direct connection for migrations (Neon)
DATABASE_URL_UNPOOLED="postgresql://user:***@host:5432/db?sslmode=require"

# NextAuth (generate: openssl rand -base64 64)
AUTH_SECRET="your-auth-secret-here"

# AI Provider — OpenCode AI Zen
OPENAI_API_KEY="sk-zen-..."
OPENAI_BASE_URL="https://opencode.ai/zen/v1"
OPENAI_MODEL="deepseek-v4-flash-free"

# NextAuth URLs (set via Vercel env for production)
# AUTH_URL="https://kune-ya-com.vercel.app"
# NEXTAUTH_URL="https://kune-ya-com.vercel.app"
